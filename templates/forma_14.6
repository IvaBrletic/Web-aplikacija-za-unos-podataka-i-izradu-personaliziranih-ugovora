<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>Forma za ugovore</title>
    </head>
    <body>
        <h1>Web aplikacija za izradu ugovora</h1>

        <form action="/spremi" method="post">

            <h1>1. Podaci o tvrtki/obrtu</h1>

            <label for="Naziv">Naziv tvrtke/obrta:</label><br>
            <input type="text" id="naziv" name="naziv" required><br><br>

            <label for="OIB">OIB tvrtke:</label><br>
            <input type="text" id="oib" name="oib" pattern="\d{11}" title="OIB mora imati točno 11 znamenki" required><br><br>

            <label for="Osnovna djelatnost">Osnovna djelatnost:</label><br>
            <input type="text" id="djelatnost" name="djelatnost" required><br><br>

            <label for="NKD klasifikacija">NKD klasifikacija:</label><br>
            <input type="text" id="nkdklasifikacija" name="nkdklasifikacija" required><br><br>

            <label for="IBAN">IBAN:</label><br>
            <input type="text" id="iban" name="iban" required><br><br>

            <label for="Matični broj">Matični broj:</label><br>
            <input type="text" id="maticni_broj" name="maticni_broj" required><br><br>

            <label for="Adresa sjedišta">Adresa sjedišta:</label><br>
            <input type="text" id="adresa_sjedista" name="adresa_sjedista" required><br><br>

            <label for="Mjesto sjedišta">Mjesto sjedišta:</label><br>
            <input type="text" id="mjesto_sjedista" name="mjesto_sjedista" required><br><br>

            <label for="Postanski broj">Poštanski broj:</label><br>
            <input type="text" id="postanski_broj" name="postanski_broj" pattern="[0-9]{5}" title="Poštanski broj mora imati 5 znamenki" required><br><br>

            <label for="Županija sjedišta">Županija sjedišta:</label><br>
            <input type="text" id="zupanija_sjedista" name="zupanija_sjedista" required><br><br>

            <label for="Prihvaćate li virtualne kartice">Prihvaćate li virtualne kartice:</label><br>
            <input type="radio" id="virtualne_kartice_da" name="virtualne_kartice" value="Da"> Da<br>
            <input type="radio" id="virtualne_kartice_ne" name="virtualne_kartice" value="Ne"> Ne<br><br>

            <label for="Izvor sredstava">Izvor sredstava:</label><br>
            <input type="checkbox" id="izvor_sredstava_redovito" name="izvor_sredstava" value="Redovito poslovanje"> Redovito poslovanje<br>
            <input type="checkbox" id="izvor_sredstava_vlasnik" name="izvor_sredstava" value="Sredstva vlasnika/osnivača"> Sredstva vlasnika/osnivača<br>
            <input type="checkbox" id="izvor_sredstava_kredit" name="izvor_sredstava" value="Kredit/sredstva iz EU fondova"> Kredit/sredstva iz EU fondova<br>
            <input type="checkbox" id="izvor_sredstava_ostalo" name="izvor_sredstava" value="Ostalo"> Ostalo<br>
            <input type="text" id="izvor_ostalo" name="izvor_ostalo" placeholder="Ako je 'Ostalo', molimo navedite" size ="30"><br><br>

            <label for="Očekivani godišnji promet">Očekivani godišnji promet:</label><br>
            <input type="radio" id="promet1" name="promet" value="0-5000"> 0-5000 EUR<br>
            <input type="radio" id="promet2" name="promet" value="5001-20000"> 5001-20.0000 EUR<br>
            <input type="radio" id="promet3" name="promet" value="20001-50000"> 20.001-50.000 EUR<br>
            <input type="radio" id="promet4" name="promet" value="50001-100000"> 50.001-100.000 EUR<br>
            <input type="radio" id="promet5" name="promet" value="100001-200000"> 100.001-200.000 EUR<br>
            <input type="radio" id="promet6" name="promet" value="Vise od 200000"> VIše od 200.000 EUR<br><br>
            
            <label for="Svrha poslovnog odnosa">Svrha poslovnog odnosa:</label><br>
            <input type="checkbox" id="svrha_naplata" name="svrha" value="Naplata roba i usluga"> Naplata roba i usluga<br>
            <input type="checkbox" id="svrha_donacije" name="svrha" value="Donacije"> Donacije<br>
            <input type="checkbox" id="svrha_ostalo" name="svrha" value="Ostalo"> Ostalo<br>
            <input type="text" id="svrha_ostalo_da" name="svrha_ostalo" placeholder="Ako je 'Ostalo', molimo navedite" size ="30"><br><br>

            <h2>2. Podaci o kontakt osobi</h2>

            <label for="Ime i prezime">Ime i prezime kontakt osobe:</label><br>
            <input  type="text" id="kontakt_ime" name="kontakt_ime" required><br><br>

            <label for="E-mail">E-mail kontakt osobe:</label><br>
            <input  type="email" id="kontakt_email" name="kontakt_email" required><br><br>

            <label for="Telefon">Telefon kontakt osobe:</label><br>
            <input  type="tel" id="kontakt_telefon" name="kontakt_telefon" required><br><br>

            <h3>3. Podaci o ovlaštenoj osobi/vlasniku</h3>

            <label for="Ime i prezime">Ime i prezime ovlaštene osobe:</label><br>
            <input  type="text" id="vlasnik_ime" name="vlasnik_ime" required><br><br>

            <label for="Adresa prebivališta">Adresa prebivališta ovlaštene osobe:</label><br>
            <input  type="text" id="vlasnik_adresa" name="vlasnik_adresa" required><br><br>

            <label for="Mjesto prebivališta">Mjesto prebivališta ovlaštene osobe:</label><br>
            <input  type="text" id="vlasnik_mjesto" name="vlasnik_mjesto" required><br><br>

            <label for="Županija prebivališta">Županija prebivališta ovlaštene osobe:</label><br>
            <input  type="text" id="vlasnik_zupanija" name="vlasnik_zupanija" required><br><br>
            
            <label for="Državljanstvo">Državljanstvo ovlaštene osobe:</label><br>
            <input  type="text" id="vlasnik_drzavljanstvo" name="vlasnik_drzavljanstvo" required><br><br>

            <label for="OIB">OIB:</label><br>
            <input  type="text" id="vlasnik_OIB" name="vlasnik_OIB" pattern="\d{11}" title="OIB mora imati točno 11 znamenki" required><br><br>

            <label for="Kontakt broj">Kontakt broj:</label><br>
            <input  type="text" id="vlasnik_kontakt_broj" name="vlasnik_kontakt_broj" required><br><br>

            <label for="Broj osobne iskaznice">Broj osobne iskaznice:</label><br>
            <input  type="text" id="vlasnik_broj_osobne_iskaznice" name="vlasnik_broj_osobne_iskaznice" required><br><br>

            <label for="Datum isteka osobne iskaznice">Datum isteka osobne iskaznice:</label><br>
            <input  type="date" id="vlasnik_datum_isteka_osobne_iskaznice" name="vlasnik_datum_isteka_osobne_iskaznice" required><br><br>

            <label for="Mjesto izdavanja osobne iskaznice">Mjesto izdavanja osobne iskaznice:</label><br>
            <input  type="text" id="vlasnik_mjesto_izdavanja_osobne_iskaznice" name="vlasnik_mjesto_izdavanja_osobne_iskaznice" required><br><br>

            <label for="Datum rođenja">Datum rođenja:</label><br>
            <input  type="date" id="vlasnik_datum_rodenja" name="vlasnik_datum_rodenja" required><br><br>

            <label for="Funkcija ovlaštene osobe">Funkcija ovlaštene osobe:</label><br>
            <input  type="text" id="vlasnik_funkcija" name="vlasnik_funkcija" required><br><br>

            <label for="Udio vlasništva">Udio vlasništva (%):</label><br>
            <input  type="number" id="vlasnik_udio_vlasnistva" name="vlasnik_udio_vlasnistva" min="0" max="100" required><br><br>

            <label for="Jeste li politički izložena osoba">Jesi li politički izložena osoba:</label><br>
            <input  type="radio" id="vlasnik_politicki_izlozena_da" name="vlasnik_politicki_izlozena" value="Da"> Da<br>
            <input  type="radio" id="vlasnik_politicki_izlozena_ne" name="vlasnik_politicki_izlozena" value="Ne"> Ne<br><br>

            <h4>4. Dodatni vlasnik/osnivač</h4>

            <label for="Ime i prezime">Ime i prezime:</label><br>
            <input  type="text" id="dodatni_vlasnik_ime" name="dodatni_vlasnik_ime"><br><br>

            <label for="OIB">OIB:</label><br>
            <input  type="text" id="dodatni_vlasnik_OIB" name="dodatni_vlasnik_OIB" pattern="\d{11}" title="OIB mora imati točno 11 znamenki"><br><br>

            <label for="Udio vlasništva">Udio vlasništva (%):</label><br>
            <input  type="number" id="dodatni_vlasnik_udio_vlasnistva" name="dodatni_vlasnik_udio_vlasnistva" min="0" max="100"><br><br>

            <label for="Adresa prebivališta">Adresa prebivališta ovlaštene osobe:</label><br>
            <input  type="text" id="dodatni_vlasnik_adresa" name="dodatni_vlasnik_adresa"><br><br>

            <label for="Mjesto prebivališta">Mjesto prebivališta ovlaštene osobe:</label><br>
            <input  type="text" id="dodatni_vlasnik_mjesto" name="dodatni_vlasnik_mjesto"><br><br>

            <label for="Županija">Županija prebivališta ovlaštene osobe:</label><br>
            <input  type="text" id="dodatni_vlasnik_zupanija" name="dodatni_vlasnik_zupanija"><br><br>

            <label for="Datum rođenja">Datum rođenja:</label><br>
            <input  type="date" id="dodatni_vlasnik_datum_rodenja" name="dodatni_vlasnik_datum_rodenja"><br><br>


            <label for="Državljanstvo">Državljanstvo:</label><br>
            <input  type="text" id="dodatni_vlasnik_drzavljanstvo" name="dodatni_vlasnik_drzavljanstvo"><br><br>

            <h5>5. Podaci o poslovnom prostoru</h5>

            <label for="Naziv poslovnog prostora">Naziv poslovnog prostora:</label><br>
            <input  type="text" id="poslovni_prostor_naziv" name="poslovni_prostor_naziv" required><br><br>

            <label for="Adresa poslovnog prostora">Adresa poslovnog prostora:</label><br>
            <input  type="text" id="poslovni_prostor_adresa" name="poslovni_prostor_adresa" required><br><br>

            <label for="Vrsta robe/usluga koja se prodaje">Vrsta robe/usluga koja se prodaje:</label><br>
            <input  type="text" id="poslovni_prostor_vrsta_robe_usluga" name="poslovni_prostor_vrsta_robe_usluga" required><br><br>
            
            <label for="Radi li se o sezonskoj blagajni">Radi li se o sezonskoj blagajni:</label><br>
            <input  type="radio" id="poslovni_prostor_sezonska_blagajna_da" name="poslovni_prostor_sezonska_blagajna" value="Da"> Da<br>
            <input  type="radio" id="poslovni_prostor_sezonska_blagajna_ne" name="poslovni_prostor_sezonska_blagajna" value="Ne"> Ne<br><br>

            <label for="Imate li POS terminal druge financijske istitucije">Imate li POS terminal druge financijske istitucije:</label><br>
            <input  type="radio" id="poslovni_prostor_pos_terminal_da" name="poslovni_prostor_pos_terminal" value="Da"> Da<br>
            <input  type="radio" id="poslovni_prostor_pos_terminal_ne" name="poslovni_prostor_pos_terminal" value="Ne"> Ne<br><br>

            <label>Ako DA, navedite banku/instituciju:</label><br>
            <input  type="text" id="poslovni_prostor_banka_institucija" name="poslovni_prostor_banka_institucija"><br><br>

            <button type="submit">Spremi podatke</button>
        </form>
    </body>
</html>